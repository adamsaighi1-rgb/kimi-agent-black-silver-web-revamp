# Strapi server
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=http://localhost:1337
IS_PROXIED=false

# Security
APP_KEYS=toBeModified1,toBeModified2,toBeModified3,toBeModified4
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

# Database (local Docker default)
DATABASE_CLIENT=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_URL=
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# CORS
CORS_ALLOW_ALL=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Localization and seed
SEED_ON_BOOTSTRAP=true
STRAPI_DEFAULT_LOCALE=en

# Optional: Cloudinary upload provider (recommended for free hosting)
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# Optional Reelly import job
REELLY_IMPORT_ON_BOOTSTRAP=false
REELLY_EMAIL=
REELLY_PASSWORD=
REELLY_LIMIT=50
REELLY_LOGIN_URL=https://api.reelly.io/api:sk5LT7jx/auth/login0
REELLY_LIST_URL=https://api-reelly.up.railway.app/api/internal/projects?limit=50
REELLY_DETAIL_URL=https://api-reelly.up.railway.app/api/internal/projects/{id}
REELLY_AUTH_TOKEN=
REELLY_MEDIA_URL=https://api-reelly.up.railway.app/api/internal/projects/{id}/media
REELLY_PAYMENT_PLAN_URL=https://api-reelly.up.railway.app/api/internal/projects/{id}/payment_plan
REELLY_UNITS_URL=https://api-reelly.up.railway.app/api/internal/projects/{id}/units
REELLY_ORIGIN=https://find.reelly.io
REELLY_PAUSE_MS=150
REELLY_REQUEST_TIMEOUT_MS=30000
REELLY_DOWNLOAD_TIMEOUT_MS=90000