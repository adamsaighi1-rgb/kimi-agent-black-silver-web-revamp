{
  "kind": "collectionType",
  "collectionName": "neighborhoods",
  "info": {
    "singularName": "neighborhood",
    "pluralName": "neighborhoods",
    "displayName": "Neighborhood"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "seedKey": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": false } } },
    "name": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "listings": { "type": "integer", "required": true, "pluginOptions": { "i18n": { "localized": false } } },
    "size": {
      "type": "enumeration",
      "enum": ["large", "medium", "small"],
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "order": { "type": "integer", "default": 0, "pluginOptions": { "i18n": { "localized": false } } },
    "image": { "type": "media", "multiple": false, "required": true, "allowedTypes": ["images"], "pluginOptions": { "i18n": { "localized": true } } }
  }
}
